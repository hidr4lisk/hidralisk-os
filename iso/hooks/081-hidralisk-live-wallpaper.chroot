#!/bin/sh
# Description: Hidralisk OS - wallpaper de la sesión LIVE del instalador (override + recompila).
# El wallpaper y el override van por includes.chroot (ningún paquete los pisa); este hook
# solo recompila los schemas para que el default de la sesión live sea nuestro fondo.
set -e
glib-compile-schemas /usr/share/glib-2.0/schemas/
echo "[hidralisk] wallpaper de la sesion live -> Hidralisk"
