#!/bin/bash
# Hidralisk OS - personalizacion del 1er arranque para el usuario instalado.
#
# El instalador de Vanilla (albius) crea el usuario con un UID >=1000 (p.ej. 1200, NO 1000),
# pisa su archivo de AccountsService con `Session=firstsetup` y le copia el autostart del
# First Setup. En el 1er boot (antes de gdm) lo dejamos como Hidralisk:
#   - avatar = dragon
#   - sesion GNOME normal (sin el wizard de la "flor")
#   - shell por defecto = zsh
set -e

# usuario humano real (primer UID en rango 1000-59999; el instalador usa 1200)
U=$(getent passwd | awk -F: '$3>=1000 && $3<60000 {print $1; exit}')
[ -n "$U" ] || exit 0
H=$(getent passwd "$U" | cut -d: -f6)

# avatar = dragon
mkdir -p /var/lib/AccountsService/icons /var/lib/AccountsService/users
cp /usr/share/hidralisk/avatar.png /var/lib/AccountsService/icons/"$U"
chmod 644 /var/lib/AccountsService/icons/"$U"

# AccountsService: sesion GNOME normal (reemplaza el Session=firstsetup que pone el instalador)
# + avatar. Reescribimos el archivo entero porque el instalador lo deja con solo el firstsetup.
cat > /var/lib/AccountsService/users/"$U" <<EOF
[User]
Session=gnome
XSession=gnome
Icon=/var/lib/AccountsService/icons/$U
SystemAccount=false
EOF

# sacar el autostart del First Setup de Vanilla (la "flor") que el instalador copio al home
rm -f "$H/.config/autostart/org.vanillaos.FirstSetup.desktop"

# shell por defecto = zsh
if [ -x /usr/bin/zsh ]; then
  cur=$(getent passwd "$U" | cut -d: -f7)
  [ "$cur" = /usr/bin/zsh ] || usermod -s /usr/bin/zsh "$U" || true
fi

# contraseña por defecto (hidra/hidra, publicada en el README) → forzar el cambio en el
# primer uso: chage -d 0 expira la pass. El autologin de GDM no pide password (no lo rompe);
# el cambio se exige en el primer sudo / login con password / ssh.
chage -d 0 "$U" || true

# Flathub (repo de flatpaks) = el camino de apps de escritorio. Se registra en el 1er boot
# porque el remote vive en /var (mutable), no en la imagen /usr (solo lectura). Offline-friendly:
# el .flatpakrepo trae la GPG key embebida, asi que no baja nada al registrarlo.
if [ -x /usr/bin/flatpak ] && [ -f /usr/share/hidralisk/flathub.flatpakrepo ]; then
  flatpak remote-add --if-not-exists --system flathub /usr/share/hidralisk/flathub.flatpakrepo || true
fi
