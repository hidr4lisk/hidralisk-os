#!/bin/sh
# Hidralisk OS — 'apt' de cortesía. El sistema base es INMUTABLE (solo lectura),
# así que no hay apt tradicional. Este shim explica cómo instalar software.
# (se invoca como 'apt' y 'apt-get').
cat >&2 <<'EOF'

  Hidralisk OS es un sistema INMUTABLE: la base es de solo lectura, así que
  no se instala con apt. Nada de esto toca la base — no la podés romper.

    • App de escritorio (lo normal):   abrí "Software", o bien:
                             flatpak install <app>
    • Herramienta de CLI (tipo apt):   apx  — un Ubuntu con apt en un contenedor:
                             apx subsystems new --stack ubuntu     (una sola vez, te pide un nombre)
                             apx <nombre> install <paquete>        (apt por dentro)
                             apx <nombre> enter                    (o entrás y usás apt normal)
    • Agregar a la base:   sudo abroot pkg add <paquete>   (avanzado; requiere reboot)

  Más info: https://github.com/hidr4lisk/hidralisk-os

EOF
exit 127
