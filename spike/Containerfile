# Hidralisk OS — Spike-1: imagen bootc mínima derivada de Debian
#
# Valida en concreto la tesis del ADR-001: en vez de construir init / gestor de
# paquetes / integridad propios, DERIVAMOS de una base Debian-bootc ya hecha y
# le agregamos SOLO nuestra capa de valor (seguridad por defecto + identidad).
#
# Build (en jarvis, con Docker):
#   docker build -t hidralisk-os:spike ~/repos/hidralisk-os/spike
#
# Lo que prueba:
#   1. Que se puede derivar de una base Debian-bootc (FROM).
#   2. Que el layering de apt en build funciona (apt install).
#   3. Que tras nuestra capa SIGUE siendo una imagen bootc válida (bootc container lint).
#
# Lo que NO prueba (→ Spike-2, requiere qemu): bootear la imagen como SO real.

FROM ghcr.io/bootcrew/debian-bootc:latest

# ── Capa "seguridad por defecto" (token del diferenciador del ADR §4) ─────────
# En fases siguientes, HARDENING.md se materializa entero acá. Esto es la muestra.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        openssh-server ufw htop ca-certificates && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Hardening mínimo de kernel vía sysctl (HARDENING.md → config real)
COPY hardening.sysctl /usr/lib/sysctl.d/90-hidralisk.conf

# Identidad de la distro
RUN printf 'NAME="Hidralisk OS"\nID=hidralisk-os\nVARIANT="spike"\nBUILD_DATE="%s"\n' \
        "$(date -u +%Y-%m-%d)" > /etc/hidralisk-os-release

# ── Validación: ¿sigue siendo una imagen bootc bien formada? ──────────────────
RUN bootc container lint
